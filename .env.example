# ============================================================
# New Level Premium — environment variables
# Copy this file to `.env.local` and fill in the values.
# The AI concierge is provider-agnostic — use ONE of the options below.
# ============================================================

# --- Option A (in use): self-hosted OpenAI-compatible endpoint --------------
# e.g. Sokrates running on the NVIDIA DGX, exposed via Cloudflare.
AI_API_URL=https://your-endpoint.example.com/api
AI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
AI_CHAT_COMPLETIONS_PATH=/chat/completions
# Available models on your endpoint:
AI_MODEL_FAST=sokrates-fast
AI_MODEL_REASONING=qwen3.6-35b
AI_MODEL_GERMAN_COPY=gemma4-31b
AI_MODEL_PRO=sokrates-pro
# Which model the on-site concierge should use (defaults to AI_MODEL_FAST):
# AI_MODEL_CHAT=sokrates-fast

# --- Option B: Anthropic (Claude) -------------------------------------------
# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=

# --- Option C: OpenAI --------------------------------------------------------
# AI_PROVIDER=openai
# OPENAI_API_KEY=
# AI_MODEL=gpt-4o-mini

# --- Site --------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
